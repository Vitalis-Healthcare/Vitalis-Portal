# ============================================================
# VITALIS PORTAL — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase — get these from your Supabase project dashboard
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key (for admin operations like inviting users)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App Config
NEXT_PUBLIC_APP_NAME=Vitalis Portal
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email Notifications (Phase 6) ──────────────────────────────
# Get a free key at https://resend.com — needed for email features
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sender address verified in your Resend account
NOTIFY_FROM_EMAIL=Vitalis Portal <notifications@vitalis.care>

# Portal base URL (no trailing slash)
NEXT_PUBLIC_PORTAL_URL=https://vitalis-portal.vercel.app
